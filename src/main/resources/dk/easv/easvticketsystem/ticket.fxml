<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="dk.easv.easvticketsystem.GUI.TicketController"
      alignment="CENTER" spacing="15">

    <VBox spacing="12" maxWidth="360" styleClass="card">
        <Label text="Sell Ticket" styleClass="title"/>
        <Button text="Free Ticket" onAction="#openFreeTicket" styleClass="secondary-btn"/>
        <Label fx:id="eventNameLabel" styleClass="subtitle"/>
        <ComboBox fx:id="type"/>
        <Button text="Generate Ticket" onAction="#generate" styleClass="primary-btn"/>
        <Label fx:id="ticketId" styleClass="subtitle"/>
    </VBox>
</VBox>