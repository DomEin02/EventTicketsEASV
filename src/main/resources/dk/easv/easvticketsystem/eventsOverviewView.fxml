<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dk.easv.easvticketsystem.GUI.EventsOverviewController"
            style="-fx-padding: 25;">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="20"
              alignment="CENTER_LEFT"
              styleClass="header"
              style="-fx-padding:15;">

            <Label text="Events Overview" styleClass="headerTitle"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Logged in as: admin" styleClass="subtitle"/>

            <Button text="Logout"
                    onAction="#logout"
                    styleClass="secondary-btn"/>

        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="10" styleClass="card">

            <Label text="Events Overview" styleClass="title"/>

            <!-- TABLE HEADER -->
            <HBox spacing="20">
                <Label text="Title" prefWidth="180"/>
                <Label text="Date" prefWidth="120"/>
                <Label text="Location" prefWidth="220"/>
                <Label text="Coordinator" prefWidth="140"/>
                <Label text="Tickets" prefWidth="100"/>
                <Label text="Actions" prefWidth="120"/>
            </HBox>

            <Separator/>

            <!-- EVENTS LIST -->
            <VBox fx:id="eventContainer" spacing="8"/>

        </VBox>
    </center>

</BorderPane>