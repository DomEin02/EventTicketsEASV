<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dk.easv.easvticketsystem.GUI.AdminMenuController"
            styleClass="root">

    <!-- HEADER -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="header" style="-fx-padding:15;">

            <Label text="Admin Panel" styleClass="headerTitle"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Logged in as: admin" styleClass="subtitle"/>

            <Button text="Logout"
                    onAction="#logout"
                    styleClass="secondary-btn"/>
        </HBox>
    </top>

    <!-- CENTER MENU -->
    <center>
        <VBox spacing="25" alignment="CENTER">

            <Label text="What do you want to manage?"
                   styleClass="title"/>

            <HBox spacing="30" alignment="CENTER">

                <VBox spacing="10" alignment="CENTER" styleClass="card">
                    <Label text="User Management" styleClass="title"/>
                    <Button text="Open"
                            onAction="#openUsers"
                            styleClass="primary-btn"/>
                </VBox>

                <VBox spacing="10" alignment="CENTER" styleClass="card">
                    <Label text="Events Overview" styleClass="title"/>
                    <Button text="Open"
                            onAction="#openEvents"
                            styleClass="primary-btn"/>
                </VBox>

            </HBox>

        </VBox>
    </center>

</BorderPane>
